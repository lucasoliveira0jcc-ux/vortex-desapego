# Porta em que a API vai rodar
PORT=4000

# Segredo usado para assinar os tokens JWT (troque por algo aleatório em produção)
JWT_SECRET=troque-este-segredo-em-producao

# Tempo de expiração do token
JWT_EXPIRES_IN=7d

# Origens permitidas para CORS (separadas por vírgula). Use * para liberar geral em dev.
CORS_ORIGIN=*
